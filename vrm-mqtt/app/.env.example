# VRM REST API
VRM_API_TOKEN=your_personal_access_token_here
VRM_API_BASE_URL=https://vrmapi.victronenergy.com/v2

# How often (ms) to poll VRM for installation list changes. Default: 300000 (5 min).
VRM_POLL_INTERVAL_MS=300000

# Comma-separated list of VRM portal IDs to skip (e.g. "123,456"). Default: none.
VRM_DISABLED_INSTALLATION_IDS=

# Delay (ms) between starting each installation's VRM MQTT connection on startup/reconcile. Default: 500.
VRM_INSTALLATION_STARTUP_DELAY_MS=500

# Global cross-installation message coalescing flush interval (ms). 0 = bypass. Default: 500.
VRM_THROTTLE_INTERVAL_MS=500

# Per-installation staleness timeout in ms. 0 = disable. Default: 300000 (5 min).
VRM_OFFLINE_TIMEOUT_MS=300000

# Home Assistant Mosquitto broker
HA_MQTT_HOST=localhost
HA_MQTT_PORT=1883
HA_MQTT_USERNAME=
HA_MQTT_PASSWORD=